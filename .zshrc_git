### Git
alias g="git"
alias gui="gitui"

function gitcred {
    git config user.name "${GIT_AUTHOR_NAME:-Your Name}"
    git config user.email "${GIT_AUTHOR_EMAIL:-you@example.com}"
}

alias gd="DELTA_FEATURES=+side-by-side g d"
alias gdc="DELTA_FEATURES=+side-by-side g dc"

# [Git diff stats] total delta of lines added/removed
function gds = {
    echo ">>> File stats:"
    echo ""
    git diff --name-status --diff-filter=AMD "$@" | awk '{count[$1]++} END {print "Added:", count["A"]+0; print "Modified:", count["M"]+0; print "Deleted:", count["D"]+0}'
    echo ""
    echo ">>> Line stats:"
    echo ""
    git diff --numstat --format="" "$@" | awk '{added+=$1; deleted+=$2} END {printf "Total Delta: %d (+%d, -%d)\n", added-deleted, added, deleted}'
}

# [Git log with preview]
#
# Useful to search on patches and
# get a list + preview (which gitui & lazygit don't do).
#
# It outputs the short hash of the selected commit (so you can compose
# with git show, git cherry pick or whatever you would like).
#
# Based on https://gist.github.com/akatrevorjay/9fc061e8371529c4007689a696d33c62
function gl {
    local g=(
        git log 
            --color=always 
            --pretty='%C(red)%h %C(reset)%s %C(bold blue)%an, %C(green)%cr%C(yellow)%d %C(reset)'
            "$@"
    )

    local f=(
        fzf
            --ansi
            --reverse
            --tiebreak=index
            --no-sort
            --bind=ctrl-s:toggle-sort
            --preview 'f() { set -- $(echo -- "$@" | grep -o "[a-f0-9]\{7\}"); [ $# -eq 0 ] || git show --color=always $1; }; f {}'
    )

    $g | $f | awk '{print $1}'
}

# [Git worktree]
#
# Create a worktree on parent dir
function gw {
    local friendlyName=$1
    local gitRef=$2
    local worktreeDir=''

    currentDir=$(echo $PWD | rev | cut -d'/' -f1 | rev)
    worktreeDir=$currentDir-$friendlyName

    git fetch origin
    git worktree add -f ../$worktreeDir $gitRef

    echo '>>> Done, taking you to the directory of the new worktree'
    cd ../$worktreeDir
}

# [Git branch: list]
alias gb="git for-each-ref --format='%(refname:short) | %(committerdate) | %(authorname)' refs/heads/ "

# [Git branch: picker]
alias gbf="gb | fzf --multi | cut -d'|' -f1 | tr -d ' '"
