### Win/Cmd key is MOD key

set $mod Mod4


### Executions

# Default executions
include /etc/sway/config.d/*

# General executions

# Polkit
exec /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1

# Clipboard
exec wl-paste --watch cliphist store
exec wl-paste --type image --watch cliphist store

# Day/Night modes
exec wlsunset -S 07:30 -s 20:00 -t 3500 -T 6500

# IDLE management
exec swayidle -w \
    timeout 150 'brightnessctl -s set 10%; wlsunset -g 0.9 -d 5 &' \
    resume 'brightnessctl -r; pkill -f "wlsunset -g"' \
    timeout 210 'swaylock -f -c 000000' \
    timeout 600 'swaymsg "output * dpms off"' \
    resume 'swaymsg "output * dpms on"' \
    timeout 750 'systemctl suspend' \
    before-sleep 'swaylock -f -c 000000'

# Obsidian sync
exec obsidian-sync


### Display configs (usually generated by nwg-displays)

# Check lid state on reload/startup 
# IMPORTANT: bindswitch was removed since it was overriding the configs from profiles
exec_always bash -c 'if grep -q open /proc/acpi/button/lid/LID*/state; then swaymsg output eDP-1 enable; else swaymsg output eDP-1 disable; fi'

include ./profiles/current/outputs
include ./profiles/current/workspaces


### Input

mouse_warping container

input type:keyboard {
    xkb_layout us
    xkb_variant altgr-intl
}

input type:touchpad {
    natural_scroll enabled
    tap enabled
}

input type:pointer {
    natural_scroll enabled
}


### Status Bar

bar {

  # TODO: Investigage why sometimes switch between them fixes auto-open of waybar
  # swaybar_command sh -c 'killall waybar ; waybar'
  swaybar_command waybar
}

### Styling

gaps inner 10

for_window [class=".*"] border pixel 2
for_window [shell="xwayland"] title_format "[XWayland] %title"

# client.focused <border> <background> <text> <indicator> <child_border>
set $white #FFFFFF
client.focused $white $white $white $white $white

output * background $HOME/Wallpapers/current fill


### App bindings (Mod4 = Win/Cmd key)

bindsym $mod+Return exec alacritty

bindsym $mod+Space exec rofi -show
bindsym $mod+Alt+Space exec rofi -show run
bindsym $mod+Ctrl+Space exec rofi -show filebrowsebr
bindsym $mod+Alt+Ctrl+Space exec rofi -show window
bindsym $mod+Equal exec rofi -show calc -modi calc -no-show-match -no-sort -calc-command "echo -n '{result}' | wl-copy"

bindsym $mod+v exec cliphist list | rofi -dmenu | cliphist decode | wl-copy | wl-paste
bindsym $mod+Alt+v exec rofi -show emoji

bindsym $mod+n exec obsidian
bindsym $mod+x exec nautilus --new-window

bindsym $mod+e exec alacritty -e nvim
bindsym $mod+c exec alacritty -e nvim ~/.config/sway/config

bindsym $mod+b exec brave
bindsym $mod+F1 exec brave --app=https://chatgpt.com

bindsym $mod+p exec sh -c 'grimshot savecopy window; notify-send "📷 Window saved on clipboard and filesystem!"'
bindsym $mod+Alt+p exec sh -c 'grimshot savecopy area; notify-send "📷 Area saved on clipboard and filesystem!"'
bindsym $mod+Shift+p exec sh -c 'grimshot savecopy output; notify-send "📷 Output saved on clipboard and filesystem!"'



### Session bindings

bindsym $mod+Shift+q exit
bindsym $mod+Ctrl+Alt+l exec swaylock -c 000000 -f

bindsym $mod+Alt+b exec sh -c 'killall waybar ; waybar'
bindsym $mod+Shift+b exec killall waybar

bindsym $mod+Shift+r reload


### Window bindings

bindsym $mod+f fullscreen
bindsym $mod+q kill

bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

bindsym $mod+Alt+h move left
bindsym $mod+Alt+j move down
bindsym $mod+Alt+k move up
bindsym $mod+Alt+l move right

bindsym $mod+Tab workspace back_and_forth

# Resize windows
bindsym $mod+Shift+l resize grow width 50px
bindsym $mod+Shift+h resize shrink width 50px
bindsym $mod+Shift+k resize grow height 50px
bindsym $mod+Shift+j resize shrink height 50px

# Move windows with mod + RMB and dragging
floating_modifier $mod normal

# Toggles
bindsym $mod+s splitt
bindsym $mod+BackSlash splitv
bindsym $mod+Shift+BackSlash splith


### Workspace bindings

bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8

bindsym $mod+Shift+1 move container to workspace number 1, workspace 1
bindsym $mod+Shift+2 move container to workspace number 2, workspace 2
bindsym $mod+Shift+3 move container to workspace number 3, workspace 3
bindsym $mod+Shift+4 move container to workspace number 4, workspace 4
bindsym $mod+Shift+5 move container to workspace number 5, workspace 5
bindsym $mod+Shift+6 move container to workspace number 6, workspace 6
bindsym $mod+Shift+7 move container to workspace number 7, workspace 7
bindsym $mod+Shift+8 move container to workspace number 8, workspace 8


### Output bindings

bindsym $mod+BracketRight focus output right
bindsym $mod+BracketLeft focus output left
bindsym $mod+Shift+BracketRight move window to output right, focus output right
bindsym $mod+Shift+BracketLeft move window to output left, focus output left


### Multi-media / Special keys bindings

# Audio
bindsym --locked XF86AudioRaiseVolume exec wpctl set-volume \@DEFAULT_AUDIO_SINK@ 5%+
bindsym --locked XF86AudioLowerVolume exec wpctl set-volume \@DEFAULT_AUDIO_SINK@ 5%-
bindsym --locked XF86AudioMute exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindsym --locked XF86AudioMicMute exec wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle

# Brightness
bindsym --locked XF86MonBrightnessDown exec brightnessctl s 10%-
bindsym --locked XF86MonBrightnessUp exec brightnessctl s 10%+ 
bindsym --locked XF86KbdBrightnessUp exec brightnessctl -d :white:kbd_backlight s 10%+
bindsym --locked XF86KbdBrightnessDown exec brightnessctl -d :white:kbd_backlight s 10%-

# Playback
bindsym --locked XF86AudioNext exec playerctl next
bindsym --locked XF86AudioPause exec playerctl play-pause
bindsym --locked XF86AudioPlay exec playerctl play-pause
bindsym --locked XF86AudioPrev exec playerctl previous
